FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./

RUN npm ci --include=dev

COPY tsconfig.json ./
COPY src ./src

RUN npm run build

# --- Production image ---
FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache python3 make g++

COPY package*.json ./

RUN npm ci --production

COPY --from=builder /app/dist ./dist

RUN mkdir -p keys uploads

EXPOSE 3001

CMD ["node", "dist/server.js"]
