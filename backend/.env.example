PORT=3001
NODE_ENV=development

DB_HOST=mysql
DB_PORT=3306
DB_NAME=l9trends
DB_USER=root
DB_PASSWORD=rootpassword

REDIS_HOST=redis
REDIS_PORT=6379

JWT_EXPIRES_IN=7d
# JWT keys are auto-generated at backend/keys/ on first startup (RS256)

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gmail/callback

ENCRYPTION_KEY=your-32-byte-hex-encryption-key
# Generate with: openssl rand -hex 32
# NEVER change this after first deploy — it encrypts all stored Gmail tokens

CORS_ORIGIN=http://YOUR_EC2_IP
