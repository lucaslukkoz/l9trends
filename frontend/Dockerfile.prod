FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

RUN npm run build

# --- Production image ---
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

# Copia build do Next.js
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/next.config.js ./ 

# Copia public somente se existir
RUN if [ -d /app/public ]; then cp -r /app/public ./public; else echo "No public folder"; fi

EXPOSE 3000

CMD ["npm", "start"]